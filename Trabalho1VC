import cv2
import matplotlib.pyplot as plt
import os
import numpy as np

def equalizar_canal_manual(canal):
    """Aplica a equalização de histograma matemática em um canal 2D."""
    # 1. Histograma
    hist, bins = np.histogram(canal.flatten(), 256, [0, 256])
    
    # 2. CDF (Função de Distribuição Acumulada)
    cdf = hist.cumsum()
    
    # 3. Normalização para o intervalo [0, 255]
    cdf_m = np.ma.masked_equal(cdf, 0)
    cdf_m = (cdf_m - cdf_m.min()) * 255 / (cdf_m.max() - cdf_m.min())
    cdf_final = np.ma.filled(cdf_m, 0).astype('uint8')
    
    # 4. Mapeamento dos pixels
    return cdf_final[canal]

def processar_imagens(lista_fotos, pasta_origem, pasta_destino, eh_rgb=False):
    if not os.path.exists(pasta_destino):
        os.makedirs(pasta_destino)

    for nome_arquivo in lista_fotos:
        caminho_entrada = os.path.join(pasta_origem, nome_arquivo)
        
        img_bgr = cv2.imread(caminho_entrada)
        if img_bgr is None:
            print(f"Erro: Não encontrei {nome_arquivo} em {pasta_origem}")
            continue

        if eh_rgb:
            img_hsv = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2HSV)
            h, s, v = cv2.split(img_hsv)
            
            v_eq = equalizar_canal_manual(v)
            
            img_hsv_eq = cv2.merge([h, s, v_eq])
            img_final = cv2.cvtColor(img_hsv_eq, cv2.COLOR_HSV2RGB) # Para o Matplotlib
            img_original_display = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB) # Para o Matplotlib
            img_negativo = 255 - img_original_display
        else:
            img_cinza = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
            img_final = equalizar_canal_manual(img_cinza)
            img_original_display = img_cinza
            img_negativo = 255 - img_cinza

        # Visualização
        fig, axes = plt.subplots(1, 3, figsize=(15, 5))
        cmap = 'gray' if not eh_rgb else None
        
        axes[0].imshow(img_original_display, cmap=cmap)
        axes[0].set_title(f"Original: {nome_arquivo}")
        
        axes[1].imshow(img_final, cmap=cmap)
        axes[1].set_title("Equalizada (Manual)")
        
        axes[2].imshow(img_negativo, cmap=cmap)
        axes[2].set_title("Negativo")

        nome_base = os.path.splitext(nome_arquivo)[0]
        caminho_saida = os.path.join(pasta_destino, f"res_{nome_base}.png")
        
        plt.savefig(caminho_saida)
        plt.close()
        print(f"Finalizado: {pasta_origem}/{nome_arquivo} -> {caminho_saida}")

# --- EXECUÇÃO DO EXPERIMENTO ---

fotos_pb = ['foto_1.jpg', 'foto_2.jpg', 'foto_3.jpg', 'foto_4.jpg']
fotos_coloridas = ['colorida_1.jpg', 'colorida_2.jpg', 'colorida_3.jpg', 'colorida_4.jpg']

processar_imagens(fotos_pb, 'fotos', 'resultados', eh_rgb=False)

processar_imagens(fotos_coloridas, 'fotosrgb', 'resultadosrgb', eh_rgb=True)
